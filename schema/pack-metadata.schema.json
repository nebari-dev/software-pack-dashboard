{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nebari-dev/pack-dashboard/blob/main/schema/pack-metadata.schema.json",
  "title": "Nebari pack metadata",
  "description": "Schema for the pack-metadata.yaml file placed at the root of each first-party Nebari pack repository.",
  "type": "object",
  "required": [
    "name",
    "display_name",
    "description",
    "level",
    "owner",
    "deprecated"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Must equal the GitHub repo name."
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "level": {
      "type": "string",
      "enum": ["experimental", "alpha", "beta", "ga"]
    },
    "owner": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^@].*$",
      "description": "GitHub username, no @ prefix."
    },
    "deprecated": {
      "type": "boolean"
    },
    "sunset_date": {
      "type": ["string", "null"],
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "product_owner": {
      "type": ["string", "null"]
    },
    "nebariapp_integration": {
      "type": "string",
      "enum": ["none", "partial", "full", "na"],
      "default": "na"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "standalone-supported": {
          "type": ["boolean", "string"],
          "enum": [true, false, "yes", "no"]
        }
      }
    },
    "last_promoted_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "last_promoted_pr": {
      "type": "integer",
      "minimum": 1
    },
    "demo_notes": {
      "type": "string",
      "maxLength": 500
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "docs": {
          "type": "string",
          "format": "uri"
        },
        "demo": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "deprecated": { "const": true } },
        "required": ["deprecated"]
      },
      "then": {
        "required": ["sunset_date"],
        "properties": {
          "sunset_date": { "type": "string" }
        }
      }
    },
    {
      "if": {
        "properties": { "level": { "const": "ga" } },
        "required": ["level"]
      },
      "then": {
        "required": ["product_owner"],
        "properties": {
          "product_owner": { "type": "string", "minLength": 1 }
        }
      }
    }
  ]
}
